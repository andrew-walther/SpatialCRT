	keywords = {Animals, Anopheles, Bedding and Linens, Child, Preschool, Cluster Analysis, Fresh Water, Geography, Ghana, Humans, Infant, Insect Vectors, Insecticides, Malaria, Falciparum, Mortality, Permethrin, Poisson Distribution, Population Density, Pyrethrins, Regression Analysis, Risk Factors},
	pages = {80--85},
