@article{bivand_r_2022,
	title = {R {Packages} for {Analyzing} {Spatial} {Data}: {A} {Comparative} {Case} {Study} with {Areal} {Data}},
	volume = {54},
	issn = {0016-7363, 1538-4632},
	shorttitle = {R {Packages} for {Analyzing} {Spatial} {Data}},
	url = {https://onlinelibrary.wiley.com/doi/10.1111/gean.12319},
	doi = {10.1111/gean.12319},
	abstract = {The count of open source software packages hosted by the Comprehensive R Archive Network (CRAN) using key spatial data handling packages has now passed 1,000. Providing a comprehensive review of these packages is beyond the scope of an article. Consequently, this review takes the form of a comparative case study, reproducing some of the approach and workflow of a spatial analysis of a data set including almost all the census tracts in the coterminous United States. The case study moves from visualization and the construction of a spatial weights matrix, to exploratory spatial data analysis and spatial regression. For comparison, implementations of the same steps in PySAL and GeoDa are interwoven, and points of convergence and divergence noted and discussed. Conclusions are drawn about the usefulness of open source software, the significance of sharing contributions both in software implementation but also more broadly in reproducible research, and in opportunities for exchanging ideas and solutions with other research domains.},
	language = {en},
	number = {3},
	urldate = {2025-06-30},
	journal = {Geographical Analysis},
	author = {Bivand, Roger},
	month = jul,
	year = {2022},
	pages = {488--518},
}

@misc{bivand_spdep_2002,
	title = {spdep: {Spatial} {Dependence}: {Weighting} {Schemes}, {Statistics}},
	shorttitle = {spdep},
	url = {https://CRAN.R-project.org/package=spdep},
	doi = {10.32614/CRAN.package.spdep},
	abstract = {A collection of functions to create spatial weights matrix objects from polygon 'contiguities', from point patterns by distance and tessellations, for summarizing these objects, and for permitting their use in spatial data analysis, including regional aggregation by minimum spanning tree; a collection of tests for spatial 'autocorrelation', including global 'Morans I' and 'Gearys C' proposed by 'Cliff' and 'Ord' (1973, ISBN: 0850860369) and (1981, ISBN: 0850860814), 'Hubert/Mantel' general cross product statistic, Empirical Bayes estimates and 'Assunção/Reis' (1999) {\textless}doi:10.1002/(SICI)1097-0258(19990830)18:16\%3C2147::AID-SIM179\%3E3.0.CO;2-I{\textgreater} Index, 'Getis/Ord' G ('Getis' and 'Ord' 1992) {\textless}doi:10.1111/j.1538-4632.1992.tb00261.x{\textgreater} and multicoloured join count statistics, 'APLE' ('Li 'et al.' ) {\textless}doi:10.1111/j.1538-4632.2007.00708.x{\textgreater}, local 'Moran's I', 'Gearys C'  ('Anselin' 1995) {\textless}doi:10.1111/j.1538-4632.1995.tb00338.x{\textgreater} and 'Getis/Ord' G ('Ord' and 'Getis' 1995) {\textless}doi:10.1111/j.1538-4632.1995.tb00912.x{\textgreater}, 'saddlepoint' approximations ('Tiefelsdorf' 2002) {\textless}doi:10.1111/j.1538-4632.2002.tb01084.x{\textgreater} and exact tests for global and local 'Moran's I' ('Bivand et al.' 2009) {\textless}doi:10.1016/j.csda.2008.07.021{\textgreater} and 'LOSH' local indicators of spatial heteroscedasticity ('Ord' and 'Getis') {\textless}doi:10.1007/s00168-011-0492-y{\textgreater}. The implementation of most of these measures is described in 'Bivand' and 'Wong' (2018) {\textless}doi:10.1007/s11749-018-0599-x{\textgreater}, with further extensions in 'Bivand' (2022) {\textless}doi:10.1111/gean.12319{\textgreater}. 'Lagrange' multiplier tests for spatial dependence in linear models are provided ('Anselin et al'. 1996) {\textless}doi:10.1016/0166-0462(95)02111-6{\textgreater}, as are 'Rao' score tests for hypothesised spatial 'Durbin' models based on linear models ('Koley' and 'Bera' 2023) {\textless}doi:10.1080/17421772.2023.2256810{\textgreater}. Additions in 2024 include Local Indicators for Categorical Data based on 'Carrer' et al. (2021) {\textless}doi:10.1016/j.jas.2020.105306{\textgreater} and 'Bivand' et al. (2017) {\textless}doi:10.1016/j.spasta.2017.03.003{\textgreater}; also Weighted Multivariate Spatial Autocorrelation Measures ('Bavaud' 2024) {\textless}doi:10.1111/gean.12390{\textgreater}. {\textless}doi:10.1080/17421772.2023.2256810{\textgreater}. A local indicators for categorical data (LICD) implementation based on 'Carrer et al.' (2021)  {\textless}doi:10.1016/j.jas.2020.105306{\textgreater} and 'Bivand et al.' (2017)  {\textless}doi:10.1016/j.spasta.2017.03.003{\textgreater} was added in 1.3-7. Multivariate 'spatialdelta' ('Bavaud' 2024) {\textless}doi:10.1111/gean.12390{\textgreater} was added in 1.3-13. From 'spdep' and 'spatialreg' versions {\textgreater}= 1.2-1, the model fitting functions previously present in this package are defunct in 'spdep' and may be found in 'spatialreg'.},
	language = {en},
	urldate = {2025-06-30},
	author = {Bivand, Roger},
	month = mar,
	year = {2002},
	note = {Institution: Comprehensive R Archive Network
Pages: 1.3-13},
}

